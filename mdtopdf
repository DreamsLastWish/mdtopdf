#!/usr/bin/env python3
"""Terminal entrypoint for md_to_pdf_converter.py."""

from __future__ import annotations

import runpy
import sys
from pathlib import Path


script = Path(__file__).resolve().with_name("md_to_pdf_converter.py")
if not script.exists():
    print(f"mdtopdf error: converter script not found: {script}", file=sys.stderr)
    raise SystemExit(1)

sys.argv = [str(script), *sys.argv[1:]]
runpy.run_path(str(script), run_name="__main__")

